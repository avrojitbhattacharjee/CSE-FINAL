//Patter type 1 print 1 22 33 44 Triangled
#include<stdio.h>
int main()
{
    int raw,col,n;
    printf("Enter a number: ");
    scanf("%d",&n);

    for(raw=1; raw<=n; raw++){
        for(col=1; col<=raw; col++){
            printf("%d",raw);
        }
        printf("\n");
        
    }
    
    return 0;
}
